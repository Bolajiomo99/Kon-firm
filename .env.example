# Kon-firm environment configuration — TEMPLATE ONLY
#
# ⚠️  THIS FILE IS COMMITTED TO THE PUBLIC REPOSITORY.
#     It must never contain real values. Placeholders only.
#     Your real secrets belong in .env, which is gitignored.
#
# SETUP:
#   cp .env.example .env
#   then edit .env — never this file.
#
# If a real key ever lands in here or in git history, treat it as public and
# rotate it immediately from the provider's dashboard.

# ---- Monnify ----
# From the Monnify dashboard: Developer > API Keys & Contracts.
# Make sure the dashboard toggle (top-right) is set to Test Mode (orange).
# Test credentials are prefixed MK_TEST_.
MONNIFY_API_KEY=MK_TEST_XXXXXXXXXX
MONNIFY_SECRET_KEY=your_monnify_secret_key_here
MONNIFY_CONTRACT_CODE=your_contract_code_here

# Sandbox: https://sandbox.monnify.com   (test keys, no real money)
# Live:    https://api.monnify.com       (requires completed KYC/activation)
# The client refuses to run MK_TEST_ keys against the live URL.
MONNIFY_BASE_URL=https://sandbox.monnify.com

# Where Monnify sends the customer after payment.
KONFIRM_REDIRECT_URL=http://localhost:8080/payment/callback

# ---- Database ----
# Hosted Postgres (Neon / Render). Use the pooled connection string.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ---- Admin bootstrap ----
# The first admin account, created on boot. Someone has to be able to sign in
# before anyone can be granted a role.
# Password must be 8+ characters with letters and numbers.
KONFIRM_ADMIN_PHONE=08031234567
KONFIRM_ADMIN_NAME=Store Manager
KONFIRM_ADMIN_PASSWORD=change-me-2026

# ---- Server ----
PORT=8080
# ENV=production enables Secure cookies and the __Host- cookie prefix.
ENV=development
